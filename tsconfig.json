{
    "$schema": "https://raw.githubusercontent.com/TypeScriptToLua/TypeScriptToLua/master/tsconfig-schema.json",
    "extends": "factorio-types/tsconfig.base.json",
    "compilerOptions": {
        "paths": {
            "*": ["./*"]
        },
        "outDir": "dist/SimpleSeablock",
        "rootDir": "src"
    },
    "tstl": {
        "luaLibImport": "none"
    },
    "include": [
        "src/**/*.ts"
    ]
}